<head>
    <meta charset="UTF-8">
    <title>Bootstrap Horizontal Scroll Cards</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>

        .compare-scroll-container {
            position: relative;
            width: 100%;
        }

        .compare-scroll-btn {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background-color: rgba(255, 255, 255, 0.8);
            border: none;
            padding: 10px;
            cursor: pointer;
            pointer-events: all;
            z-index: 1000;
            transition: background 0.3s ease;
        }

        .compare-scroll-left {
            left: 10px;
        }

        .compare-scroll-right {
            right: 10px;
        }

        .card-wrapper {
            display: flex;
            overflow-x: auto;
            scroll-behavior: smooth;
            gap: 1rem;
            /* padding: 1rem 0;  */
            margin: 0;
        }

            .card-wrapper::-webkit-scrollbar {
                display: none;
            }

        .card {
            flex: 0 0 auto;
            width: 33.33%;
            min-width: 320px;
            min-height: 360px;
            background: #fff;
            border-radius: 18px;
            overflow: hidden;
            border: 1px solid #ececec;
            box-shadow: 0 6px 18px rgba(0,0,0,0.08);
            transition: all 0.35s ease;
            margin-bottom: 20px;
            cursor: pointer;
        }

            .card:hover {
                transform: translateY(-8px);
                box-shadow: 0 14px 30px rgba(0,0,0,0.16);
            }

        .compare-card {
            height: 150px;
            cursor: pointer;
        }

        .compare-scroll-btn,
        .compare-scroll-btn:focus,
        .compare-scroll-btn:active,
        .compare-scroll-btn:hover {
            background-color: rgba(255, 255, 255, 0.8);
            outline: none;
            box-shadow: none;
        }

            .compare-scroll-btn:focus {
                outline: 2px solid #555;
            }

        .card-img-top {
            width: calc(100% - 24px);
            height: 220px;
            margin: 12px;
            border-radius: 14px;
            object-fit: contain;
            background: #fff;
            transition: transform 0.4s ease;
            display: block;
        }

        .card:hover .card-img-top {
            transform: scale(1.05);
        }

        .card-body {
            padding: 20px;
            padding-top: 10px;
            text-align: center;
        }

        .card-text {
            font-size: 1.15rem;
            font-weight: 700;
            line-height: 1.5;
            color: #222;
            padding: 0 12px 10px;
        }

        .card-wrapper .card:first-child {
            margin-left: 0.5rem;
        }

        .card-wrapper .card:last-child {
            margin-right: 1rem;
        }
        .compare-now-btn:hover {
            gap: 14px;
            color: #0d3f59;
            text-decoration: none;
        }
    </style>
</head>
