    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>const container = document.getElementById('cardContainer');

        function scrollCompareLeft() {
            const card = container.querySelector('.card');

            const scrollAmount = card.offsetWidth + 16;

            container.scrollBy({
                left: -scrollAmount,
                behavior: 'smooth'
            });
        }

        function scrollCompareRight() {
            const card = container.querySelector('.card');

            const scrollAmount = card.offsetWidth + 16;

            container.scrollBy({
                left: scrollAmount,
                behavior: 'smooth'
            });
        }</script>

    <script>function navigateToComparePage(bike1, bike2) {
            const urlBike1 = encodeURIComponent(bike1.replace(/\s+/g, '-'));
            const urlBike2 = encodeURIComponent(bike2.replace(/\s+/g, '-'));
            const url = `/Compare/${urlBike1}-vs-${urlBike2}`;
            window.location.href = url;
        }</script>

