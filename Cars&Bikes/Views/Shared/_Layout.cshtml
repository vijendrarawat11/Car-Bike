        <script>$(document).ready(function () {
            $("#searchTwoWheeler").val("");
            $("#searchTwoWheeler").autocomplete({
                source: function (request, response) {
                    $.ajax({
                        url: '@Url.Action("GetTwoWheelerNames", "Home")',
                        data: { term: request.term },
                        success: function (data) {
                            // Process the data
                            response($.map(data, function (item) {
                                return {
                                    // label: item,  Display name in the dropdown
                                    // value: item   Selected value
                                    label: item.label,
                                    value: item.label,
                                    type: item.type
                                };
                            }));

                            // Automatically select the first item from the list
                            if (data.length > 0) {
                                $("#searchTwoWheeler").autocomplete("option", "autoFocus", true);
                            }
                        }
                    });
                },
                select: function (event, ui) {
                    if (ui.item.type === "TwoWheeler") {
                        // Call existing TwoWheeler redirect logic
                        $.ajax({
                            url: '@Url.Action("GetTwoWheelerDetailsByName", "Home")',
                            data: { twoWheelerName: ui.item.value },
                            success: function (data) {
                                if (data) {
                                    window.location.href = '/' + data.brandName + '/' + data.twName;
                                }
                            }
                        });
                    } else if (ui.item.type === "Compare") {
                        // Redirect using CompareItems table (assume compareUrl exists in DB)
                        window.location.href = '/Compare/' + ui.item.value.toLowerCase().replace(/\s+/g, "-");
                    }
                },
                minLength: 2 // Start searching after 2 characters
            });
        });</script>
        <script>const darkModeToggle = document.getElementById("darkModeToggle");

            darkModeToggle.addEventListener("click", () => {

                document.body.classList.toggle("dark-mode");

                if (document.body.classList.contains("dark-mode")) {
                    localStorage.setItem("theme", "dark");
                }
                else {
                    localStorage.setItem("theme", "light");
                }
            });

            window.addEventListener("load", () => {

                const savedTheme = localStorage.getItem("theme");

                if (savedTheme === "dark") {
                    document.body.classList.add("dark-mode");
                }

            });</script>
