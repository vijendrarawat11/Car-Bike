        <script>async function updateWishlistCount() {

                const badge =
                    document.getElementById("wishlistCountBadge");

                if (!badge) return;

                try {

                    const response =
                        await fetch('/Wishlist/GetWishlistCount');

                    const count =
                        await response.json();

                    badge.innerText = count;

                    if (count <= 0) {

                        badge.style.display = "none";

                    } else {

                        badge.style.display = "flex";

                    }

                } catch (error) {

                    console.log(error);

                }
            }

            document.addEventListener("DOMContentLoaded", function () {

                updateWishlistCount();

            });</script>
        <script>document.addEventListener("DOMContentLoaded", function () {

                const popup =
                    document.getElementById("authPopupOverlay");

                const guestBtn =
                    document.getElementById("guestBtn");

                if (!popup) return;

                const guestMode =
                    localStorage.getItem("bch_guest_mode");

                if (guestMode !== "true") {

                    setTimeout(() => {

                        popup.style.display = "flex";

                    }, 600);
                }

                if (guestBtn) {

                    guestBtn.addEventListener("click", function () {

                        localStorage.setItem(
                            "bch_guest_mode",
                            "true"
                        );

                        popup.style.display = "none";
                    });
                }

            });</script>
        <div class="modal"
             id="loginRequiredModal"
             tabindex="-1"
             aria-hidden="true">

            <div class="modal-dialog modal-dialog-centered">

                <div class="modal-content bch-login-modal">

                    <button type="button"
                            class="btn-close custom-close"
                            data-bs-dismiss="modal">
                    </button>

                    <div class="modal-body text-center">

                        <div class="bch-modal-logo">

                            <img src="/images/bchlogo.webp"
                                 alt="BikeCarHub">

                        </div>

                        <div class="bch-heart-circle">

                            <i class="fa-solid fa-heart"></i>

                        </div>

                        <h3>
                            Your Bike Awaits
                        </h3>

                        <p>
                            Login to add bikes to your wishlist
                            and access them anytime on BikeCarHub.
                        </p>

                        <div class="bch-modal-buttons">
                            <a href="/Account/Login"
                               class="bch-login-btn">
                                Login Now
                            </a>
                            <button type="button"
                                    class="bch-cancel-btn"
                                    data-bs-dismiss="modal">
                                Continue Browsing
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <script>document.addEventListener('hidden.bs.modal', function () {

                document.body.classList.remove('modal-open');

                document.body.style = '';

                document.querySelectorAll('.modal-backdrop')
                    .forEach(el => el.remove());

            });</script>
