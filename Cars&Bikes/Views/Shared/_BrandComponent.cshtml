<script>document.addEventListener("DOMContentLoaded", function () {

        document.querySelectorAll(".wishlist-icon")
            .forEach(icon => {

                icon.addEventListener("click", function (e) {

                    e.preventDefault();
                    e.stopPropagation();

                    const bikeData = {

                        id: icon.dataset.id
                    };

                    const isLoggedIn =
                        document.body.dataset.isauthenticated === "true";

                    if (!isLoggedIn) {

                        const modalElement =
                            document.getElementById("loginRequiredModal");

                        const existingModal =
                            bootstrap.Modal.getInstance(modalElement);

                        if (existingModal) {

                            existingModal.dispose();
                        }

                        const modal =
                            new bootstrap.Modal(modalElement, {
                                backdrop: true,
                                keyboard: true
                            });

                        modal.show();

                        return;
                    }

                    fetch('/Wishlist/AddToWishlist?twoWheelerId=' + bikeData.id, {
                        method: 'POST'
                    })
                        .then(response => {

                            if (response.ok) {

                                icon.classList.remove("fa-regular");
                                icon.classList.add("fa-solid");
                            }
                        });

                });

            });

    });</script>