@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@model TWOrFWContactUs
@* @{
        Layout = "";
    } *@
@{
    ViewData["Title"] = "Get the details about BikeCarHub";
}
@section MetaTags {
    <meta name="keywords" content="about bikecarhub, about bike,about new bikes,about bike comparison,about bikes prices" />
    <meta name="description" content="If you want to know about the BikeCarHub contact us." />
}
@if (TempData["success"] != null)
{
    @TempData["success"];
}


    
<div class="about-page">
    <div class="container-fluid about-wrapper">

        <div class="aboutus-text">

            <!-- Main Heading -->
            <h1>About Us</h1>

            <!-- Intro -->
            <p>
                Welcome to <span class="font-weight-700">BikeCarHub.com</span> —
                your trusted destination for everything related to bikes and cars in India.
                We aim to simplify vehicle research by providing reliable, easy-to-understand, and up-to-date automotive information for every type of user.
            </p>

            <!-- Who We Are -->
            <h2>Who We Are</h2>

            <p>
                BikeCarHub is built by automobile enthusiasts who are passionate about helping people make smarter vehicle decisions. Whether you are purchasing your very first scooter, comparing family cars, or exploring premium vehicles, our platform is
                designed to guide you with accurate and transparent information.
            </p>

            <p>
                We focus on delivering content that is simple, practical, and genuinely useful, so users can easily understand specifications, pricing, mileage, features, and comparisons without confusion.
            </p>

            <!-- What We Offer -->
            <h2>What We Offer</h2>

            <ul>
                <li>Detailed specifications and comparisons for bikes and cars</li>

                <li>
                    Latest ex-showroom pricing, on-road price breakdowns,
                    and mileage insights
                </li>

                <li>
                    Expert reviews, user opinions, and feature highlights
                </li>

                <li>
                    Upcoming vehicle launches and important automotive news
                </li>

            </ul>

            <!-- Why Choose Us -->
            <h2>Why Choose Us?</h2>

            <p>
                We believe vehicle research should be simple and trustworthy.
                Our goal is not just to display technical data, but to help users
                understand which vehicle best suits their budget, lifestyle,
                and daily needs.
            </p>

            <p>
                At BikeCarHub, we prioritize clarity, transparency, and user experience.
                Every piece of content is created with the intention of helping visitors
                save time and make confident decisions.
            </p>

            <!-- Mission -->
            <h2>Our Mission</h2>

            <p>
                Our mission is to create a modern automotive platform where users can
                explore bikes and cars effortlessly, compare vehicles intelligently,
                and stay updated with the latest industry trends — all in one place.
            </p>

            <!-- Get in Touch -->
            <h2>Get in Touch</h2>

            <p>
                Have questions, suggestions, or feedback?
                We would love to hear from you.
            </p>

            <p>
                Reach out to us anytime at
                <a href="mailto:info@bikecarhub.com">info@bikecarhub.com</a>
            </p>

            <!-- Closing -->
            <p>
                Thank you for visiting
                <span class="font-weight-700">BikeCarHub.com</span> —
                helping you drive smarter and ride better every day.
            </p>

        </div>
        <!-- CONTACT SECTION -->
        <div class="contact-details-container">

            <div class="row g-3 align-items-start">

                <!-- LEFT SIDE CONTACT CARDS -->
                <div class="col-lg-6">

                    <div class="row g-3">

                        <!-- ADDRESS -->
                        <div class="col-12">

                            <div class="contact-details-info">

                                <i class="bi bi-geo-alt"></i>

                                <h3>Our Address</h3>

                                <p>
                                    Lane No 5F, Shivraj Nagar, Badonwala,
                                    Uttarakhand - 248007, India
                                </p>

                            </div>

                        </div>

                        <!-- EMAIL -->
                        <div class="col-6">

                            <div class="contact-details-info small-card">

                                <i class="bi bi-envelope"></i>

                                <h3>Email Us</h3>

                                <p>
                                    info@bikecarhub.com
                                </p>

                            </div>

                        </div>

                        <!-- PHONE -->
                        <div class="col-6">

                            <div class="contact-details-info small-card">

                                <i class="bi bi-telephone"></i>

                                <h3>Call Us</h3>

                                <p>
                                    +91 8630235507
                                </p>

                            </div>

                        </div>

                    </div>
                </div>
                <!-- RIGHT SIDE FORM -->
                <div class="col-lg-6">

                    <div class="contact-form-wrapper">

                        <div class="form-header">

                            <h2>Send Us a Message</h2>

                            <p>
                                Fill out the form below and our team will get back to you shortly.
                            </p>

                        </div>

                        @if (TempData["success"] != null)
                        {
                            <p class="text-success mb-3">
                                @TempData["success"]
                            </p>
                        }

                        <form asp-action="Index" method="post" class="contact-form">

                            <div class="form-group">

                                <label asp-for="Name"></label>
                                <input asp-for="Name"
                                       class="form-control"
                                       placeholder="Enter your full name" />

                                @*<input asp-for="Name" class="form-control" />*@

                                <span asp-validation-for="Name" class="text-danger"></span>

                            </div>

                            <div class="form-group">

                                <label asp-for="PhoneNo"></label>
                                <input asp-for="PhoneNo"
                                       class="form-control"
                                       placeholder="Enter your phone number" />

                                @*<input asp-for="PhoneNo" class="form-control" />*@

                                <span asp-validation-for="PhoneNo" class="text-danger"></span>

                            </div>

                            <div class="form-group">

                                <label asp-for="Email"></label>
                                <input asp-for="Email"
                                       class="form-control"
                                       placeholder="Enter your email address" />

                                @*<input asp-for="Email" class="form-control" />*@

                                <span asp-validation-for="Email" class="text-danger"></span>

                            </div>

                            <div class="form-group">

                                <label asp-for="Message"></label>
                                <textarea asp-for="Message"
                                          class="form-control"
                                          placeholder="Write your message here..."></textarea>

                                @*<textarea asp-for="Message" class="form-control"></textarea>*@

                                <span asp-validation-for="Message" class="text-danger"></span>

                            </div>

                            <button type="submit" class="contact-form-button">

                                Submit Message
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>