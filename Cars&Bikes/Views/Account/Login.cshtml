@model Cars_Bikes.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<style>

    .auth-page {
/*        max-width: 1120px;*/
        margin: 70px auto;
        margin-top: 100px;
        margin-bottom: 40px;
    }

        .auth-page .card {
            border-radius: 20px;
            border: none;
            overflow: hidden;
        }

        .auth-page h2 {
            font-weight: 500;
            color: #222;
        }

        .auth-page .subtitle {
            color: #777;
            font-size: 15px;
/*            margin-bottom: 10px;*/
        }

        .auth-page label {
            font-weight: 600;
            margin-bottom: 7px;
            color: #333;
        }

        .auth-page input.form-control {
            height: 50px;
            border-radius: 10px;
            border: 1px solid #dcdcdc;
            box-shadow: none;
        }

            .auth-page input.form-control:focus {
                border-color: #0d6efd;
                box-shadow: none;
            }

        .auth-page .btn-primary {
            height: 50px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 16px;
        }

    .input-group .btn {
        border-radius: 0 10px 10px 0;
    }

    .forgot-link {
        font-weight: 500;
        color: #0d6efd;
        text-decoration: none;
    }

        .forgot-link:hover {
            text-decoration: underline;
        }

    .remember-box {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .password-wrapper {
        position: relative;
    }

    .auth-input {
        height: 52px;
        padding-right: 45px;
    }

    .toggle-password {
        position: absolute;
        top: 50%;
        right: 15px;
        transform: translateY(-50%);
        cursor: pointer;
        color: #777;
        font-size: 16px;
    }
    .register-link {
        font-weight: 600;
        color: #0d6efd;
        text-decoration: none;
        margin-left: 5px;
    }

        .register-link:hover {
            text-decoration: underline;
        }
</style>

<div class="container">

    <div class="row justify-content-center auth-page">

        <div class="col-md-6 col-lg-5">

            <div class="card shadow-lg p-3">

                <h2 class="text-center mb-2">
                    Welcome Back
                </h2>

                <p class="text-center subtitle">
                    Login to continue to BikeCarHub
                </p>

                <form asp-action="Login" method="post">
                    <div class="mb-3">

                        @*<label>Email or Username</label>*@
                        <label>
                            Email or Username<span class="text-danger">*</span>
                        </label>
                        <input asp-for="EmailOrPhone"
                               class="form-control" />

                    </div>

                    <div class="mb-3">
                        @*<label>Password</label>*@
                        <label>
                            Password<span class="text-danger">*</span>
                        </label>
                        <div class="password-wrapper">

                            <input asp-for="Password"
                                   type="password"
                                   class="form-control auth-input"
                                   id="passwordField" />

                            <span class="toggle-password"
                                  onclick="togglePassword()">

                                <i class="fa fa-eye"></i>

                            </span>

                        </div>
                    </div>
                    <div asp-validation-summary="All"
                         class="text-danger mb-3">
                    </div>
                    <div class="mb-4 remember-box">

                        <input asp-for="RememberMe"
                               class="form-check-input" />

                        <label asp-for="RememberMe"
                               class="m-0">
                            Remember Me
                        </label>

                    </div>

                    <button type="submit"
                            class="btn btn-primary w-100 mb-3">

                        Login

                    </button>

                    <div class="text-center">

                        <a asp-controller="Account"
                           asp-action="ForgotPassword"
                           class="forgot-link">

                            Forgot Password?

                        </a>

                    </div>
                    <div class="text-center mt-3">

                        <span class="text-muted">
                            Don’t have an account?
                        </span>

                        <a asp-controller="Account"
                           asp-action="Register"
                           class="register-link">

                            Register

                        </a>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

<script>function togglePassword() {

        const passwordInput =
            document.getElementById("passwordInput");

        if (passwordInput.type === "password") {
            passwordInput.type = "text";
        }
        else {
            passwordInput.type = "password";
        }
    }</script>
<script>function togglePassword() {

        const passwordField =
            document.getElementById("passwordField");

        const icon =
            document.querySelector(".toggle-password i");

        if (passwordField.type === "password") {

            passwordField.type = "text";

            icon.classList.remove("fa-eye");
            icon.classList.add("fa-eye-slash");

        } else {

            passwordField.type = "password";

            icon.classList.remove("fa-eye-slash");
            icon.classList.add("fa-eye");
        }
    }</script>
@section Scripts{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}