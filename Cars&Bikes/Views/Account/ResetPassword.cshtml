@model Cars_Bikes.ViewModels.ResetPasswordViewModel

<div class="container d-flex justify-content-center align-items-center"
     style="min-height:70vh;">

    <div class="card shadow p-4"
         style="width:450px;">

        <h2 class="text-center mb-4">
            Reset Password
        </h2>

        <form method="post">

            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="Token" />

            <div class="mb-3">
                <label class="form-label">
                    New Password
                </label>

                <input asp-for="NewPassword"
                       type="password"
                       id="passwordInput"
                       class="form-control" />

                <small id="passwordStrength"
                       class="text-muted">
                </small>
            </div>

            <div class="mb-3">
                <label class="form-label">
                    Confirm Password
                </label>

                <input asp-for="ConfirmPassword"
                       type="password"
                       class="form-control" />
            </div>

            <button type="submit"
                    class="btn btn-dark w-100">
                Reset Password
            </button>

        </form>

    </div>
</div>
<script>const passwordInput =
        document.getElementById("passwordInput");

    const passwordStrength =
        document.getElementById("passwordStrength");

    passwordInput.addEventListener("input", function () {

        const password = passwordInput.value;

        const hasUppercase =
            /[A-Z]/.test(password);

        const hasLowercase =
            /[a-z]/.test(password);

        const hasNumber =
            /[0-9]/.test(password);

        const hasSpecial =
            /[^A-Za-z0-9]/.test(password);

        const hasLength =
            password.length >= 6;

        let message = "";

        message += hasLength
            ? "✔ Minimum 6 characters<br>"
            : "✖ Minimum 6 characters<br>";

        message += hasUppercase
            ? "✔ Uppercase letter<br>"
            : "✖ Uppercase letter required<br>";

        message += hasLowercase
            ? "✔ Lowercase letter<br>"
            : "✖ Lowercase letter required<br>";

        message += hasNumber
            ? "✔ Numeric value<br>"
            : "✖ Numeric value required<br>";

        message += hasSpecial
            ? "✔ Special character<br>"
            : "✖ Special character required<br>";

        passwordStrength.innerHTML = message;

    });</script>