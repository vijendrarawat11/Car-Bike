@{
    ViewData["Title"] = "New Renault Duster 2026: Price, Features & Hybrid SUV | BikeCarHub";
}
@section MetaTags {
    <meta name="keywords" content="New Renault Duster,Renault Duster 2026,Renault Duster price in India,Renault Duster hybrid,Renault Duster features,Renault Duster ADAS,Renault Duster specifications,Renault Duster launch,Renault Duster mileage,Renault SUV India,BikeCarHub" />
    <meta name="description" content="Explore the new Renault Duster with turbo engines at bikecarhub, hybrid tech, ADAS, smart features, expected price ₹10 lakh, and bold SUV styling." />
}

@functions {
    public string Truncate(string input, int length)
    {
        if (string.IsNullOrEmpty(input) || input.Length <= length)
            return input;
        return input.Substring(0, length) + "...";
    }
}
<body id="bg">
