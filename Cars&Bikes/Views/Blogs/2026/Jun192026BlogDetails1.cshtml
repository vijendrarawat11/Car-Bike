@{
    ViewData["Title"] = "New Honda City Facelift 2025: Price, Features & Specs";
}
@section MetaTags {
    <meta name="keywords" content="New Honda City facelift 2025, Honda City price in India, Honda City e:HEV, Honda City hybrid mileage, Honda City vs Hyundai Verna, Honda City ZX+ features, Honda City speciﬁcations, Honda City ADAS, Honda SENSING, Honda City fuel eﬃciency, Honda City facelift review, Honda City starting price, Honda City interior features, Honda City petrol vs hybrid, Honda City variants comparison, Honda City 2026 India launch" />
    <meta name="description" content="Explore the New Honda City facelift — starting ₹11,99,900. Full specs, features, e:HEV hybrid details, safety tech, variant comparison & FAQs at BikeCarHub." />
}

@functions {
    public string Truncate(string input, int length)
    {
        if (string.IsNullOrEmpty(input) || input.Length <= length)
            return input;
        return input.Substring(0, length) + "...";
    }
}
