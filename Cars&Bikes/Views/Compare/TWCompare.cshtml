<!--For comparing 2 bikes -->
<script>
    function setDropdownAndTrigger(
        variantId,
        variantDropdownId,
        twoWheelerDropdownId,
        brandDropdownId,
        imageClass,
        nameClass,
        milageClass,
        fuelClass,
        bodyClass,
        columnId
    ) {

        if (!variantId) return;

        $.ajax({
            url: '@Url.Action("TWCompareTwoBike", "Compare")',
            type: 'GET',
            data: { variantId: variantId },

            success: function (data) {

                // Set Brand
                $(brandDropdownId).val(data.brandId).trigger('change');

                // Wait for model dropdown to populate
                setTimeout(function () {

                    $(twoWheelerDropdownId)
                        .val(data.modelId)
                        .trigger('change');

                    // Wait for variant dropdown to populate
                    setTimeout(function () {

                        $(variantDropdownId).val(variantId);

                        // Fill comparison section
                        $(imageClass).attr("src", data.imageUrl);

                        $(nameClass).text(data.modelName);

                        $(milageClass).text(data.milage);

                        $(fuelClass).text(data.fuelCapacity);

                        $(bodyClass).text(data.bodyType);

                        $(columnId).show();

                        $('#comparisonTable').show();

                    }, 1000);

                }, 1000);

            }
        });
    }

    // Call this on page load if query params exist
    $(function () {

        var variant1 = '@ViewBag.Variant1';
        var variant2 = '@ViewBag.Variant2';
        var variant3 = '@ViewBag.Variant3';
        var variant4 = '@ViewBag.Variant4';
        var variant5 = '@ViewBag.Variant5';

        // Vehicle 1
        if (variant1) {

            setDropdownAndTrigger(
                variant1,
                '#variantDropdown1',
                '#twoWheelerDropdown1',
                '#brandDropdown1',
                '.twImage1',
                '.IdTWName1',
                '.milageColumn1',
                '.fuelCapacity1',
                '.bodyType1',
                '#comparisonColumn1'
            );

        }

        // Vehicle 2
        if (variant2) {

            setDropdownAndTrigger(
                variant2,
                '#variantDropdown2',
                '#twoWheelerDropdown2',
                '#brandDropdown2',
                '.twImage2',
                '.IdTWName2',
                '.milageColumn2',
                '.fuelCapacity2',
                '.bodyType2',
                '#comparisonColumn2'
            );

        }

        // Vehicle 3
        if (variant3) {

            setDropdownAndTrigger(
                variant3,
                '#variantDropdown3',
                '#twoWheelerDropdown3',
                '#brandDropdown3',
                '.twImage3',
                '.IdTWName3',
                '.milageColumn3',
                '.fuelCapacity3',
                '.bodyType3',
                '#comparisonColumn3'
            );

        }
        // Vehicle 4
        if (variant4) {

            setDropdownAndTrigger(
                variant4,
                '#variantDropdown4',
                '#twoWheelerDropdown4',
                '#brandDropdown4',
                '.twImage4',
                '.IdTWName4',
                '.milageColumn4',
                '.fuelCapacity4',
                '.bodyType4',
                '#comparisonColumn4'
            );

        }
        // Vehicle 5
        if (variant5) {

            setDropdownAndTrigger(
                variant5,
                '#variantDropdown5',
                '#twoWheelerDropdown5',
                '#brandDropdown5',
                '.twImage5',
                '.IdTWName5',
                '.milageColumn5',
                '.fuelCapacity5',
                '.bodyType5',
                '#comparisonColumn5'
            );

        }

    });

</script>
<script>document.addEventListener("DOMContentLoaded", function () {

        let bikeCount = 2;
        const maxBikes = 5;

        const addBikeBtn = document.getElementById("addBikeBtn");
        const compareBox = document.querySelector(".compare-box");

        addBikeBtn.addEventListener("click", function () {

            bikeCount++;

            // STOP AFTER 5
            if (bikeCount > maxBikes) return;

            // HIDE BUTTON AT 5
            if (bikeCount === maxBikes) {
                addBikeBtn.style.display = "none";
            }

            const newCard = document.createElement("div");

            newCard.classList.add("compare-card");

            newCard.innerHTML = `

            <img class="twImage${bikeCount}"
                 src=""
                 alt="Bike Image"
                 onerror="this.onerror=null; this.src='/images/twowheeler/bicycle.webp';" />

            <h4>Add to compare</h4>

            <div class="compare-ddl">
                <select id="brandDropdown${bikeCount}" class="ddlcompare">
                    <option value="">--Select Brand--</option>
                </select>
            </div>

            <div class="compare-ddl">
                <select id="twoWheelerDropdown${bikeCount}" class="ddlcompare">
                    <option value="">--Select Model--</option>
                </select>
            </div>

            <div class="compare-ddl">
                <select id="variantDropdown${bikeCount}" class="ddlcompare">
                    <option value="">--Select Variant--</option>
                </select>
            </div>

        `;

            compareBox.appendChild(newCard);

            const firstBrandDropdown =
                document.getElementById("brandDropdown1");

            const newBrandDropdown =
                document.getElementById(`brandDropdown${bikeCount}`);

            const newModelDropdown =
                document.getElementById(`twoWheelerDropdown${bikeCount}`);

            const newVariantDropdown =
                document.getElementById(`variantDropdown${bikeCount}`);

            // COPY BRAND OPTIONS
            newBrandDropdown.innerHTML =
                firstBrandDropdown.innerHTML;
            newBrandDropdown.addEventListener("change", function () {

                const brandId = this.value;

                fetch('/Compare/GetTwoWheelersByBrandId?brandId=' + brandId)

                    .then(response => response.json())

                    .then(data => {

                        newModelDropdown.innerHTML =
                            '<option value="">--Select Model--</option>';

                        data.forEach(item => {

                            newModelDropdown.innerHTML +=
                                `<option value="${item.twoWheelerId}">
                                ${item.twoWheelerName}
                            </option>`;

                        });

                        // RESET VARIANTS
                        newVariantDropdown.innerHTML =
                            '<option value="">--Select Variant--</option>';

                    });

            });
            newModelDropdown.addEventListener("change", function () {

                const bikeId = this.value;

                fetch('/Compare/GetVariantsByTwoWheelerId?twoWheelerId=' + bikeId)

                    .then(response => response.json())

                    .then(data => {

                        newVariantDropdown.innerHTML =
                            '<option value="">--Select Variant--</option>';

                        data.forEach(item => {

                            newVariantDropdown.innerHTML +=
                                `<option value="${item.twVarientId}">
                                ${item.varients}
                            </option>`;

                        });

                    });

            });

        });

    });</script>