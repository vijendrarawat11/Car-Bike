    <script>$(document).ready(function () {

            const recentVehicles = JSON.parse(localStorage.getItem("recentVehicles")) || [];

            let html = '';

            recentVehicles.forEach(vehicle => {

                html += `
                                                <a href="${vehicle.url}" class="recent-card">
                                                    <img src="${vehicle.image}" alt="${vehicle.name}">
                                                    <h4>${vehicle.name}</h4>
                                                </a>
                                            `;
            });

