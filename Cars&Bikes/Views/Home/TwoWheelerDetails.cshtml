    <script>document.addEventListener('DOMContentLoaded', function () {

            const navLinks = document.querySelectorAll('.highlight li');
            const sections = document.querySelectorAll('section');
            const content = document.getElementById('content');

            if (!content || navLinks.length === 0 || sections.length === 0) {
                return;
            }

            function changeActiveLink() {

                let currentIndex = -1;

                sections.forEach((section, index) => {

                    if (!section) return;

                    const sectionTop = section.offsetTop;

                    if (content.scrollTop + 80 >= sectionTop - content.offsetTop) {
                        currentIndex = index;
                    }

                });

                navLinks.forEach(link => {
                    if (link) {
                        link.classList.remove('active');
                    }
                });

                if (currentIndex >= 0 && navLinks[currentIndex]) {
                    navLinks[currentIndex].classList.add('active');
                }
            }

            changeActiveLink();

            content.addEventListener('scroll', changeActiveLink);

            navLinks.forEach(link => {

                if (!link) return;

                link.addEventListener('click', function () {

                    const targetId = this?.getAttribute('data-target');

                    if (!targetId) return;

                    const targetElement = document.getElementById(targetId);

                    if (!targetElement) return;

                    const topOffset =
                        targetElement.offsetTop - content.offsetTop;

                    content.scrollTo({
                        top: topOffset,
                        behavior: 'smooth'
                    });

                });

            });

        });</script>
    <!--Display the data according to varients-->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            // Fetch specs on dropdown change
            $('#varientId').change(function () {
                var varientId = $(this).val();
                //alert(varientId);
                if (varientId) {
                    fetchSpec(varientId);
                }
            });

            // Fetch specs function using $.getJSON
            function fetchSpec(varientId) {
                $.getJSON('@Url.Action("GetTWSpecByVarients", "Home")', { varientId: $("#varientId").val() }, function (data) {
                    //alert(JSON.stringify(data));

                    // Update specifications table
                    var specificationsContainer = $('#specificationsContainer');
                    specificationsContainer.empty(); // Clear existing content
                    //debugger;
                    $.each(data.specs, function (index, item) {
                        var row = '<div class="container-fluid">' +
                            '<table class="contenttable">' +
                            // '<tr>' +
                            // '<th><h4>Varient :- ' + (item.varients || 'N/A') + '</h4></th>' +
                            // '<td></td>' +
                            // '</tr>' +
                            '<tr>' +
                            '<th>Mileage</th>' +
                            '<td>' + (item.milage ? item.milage + ' kmpl' : 'N/A') + '</td>' +
                            '</tr>' +
                            '<tr>' +
                            '<th>Front Brake</th>' +
                            '<td>' + (item.frontBrake || 'N/A') + '</td>' +
                            '</tr>' +
                            '<tr>' +
                            '<th>Rear Brake</th>' +
                            '<td>' + (item.rearBrake || 'N/A') + '</td>' +
                            '</tr>' +
                            '<tr>' +
                            '<th>Fuel Capacity</th>' +
                            '<td>' + (item.fuelCapacity ? item.fuelCapacity + ' L' : 'N/A') + '</td>' +
                            '</tr>' +
                            '</table>' +
                            '</div>';
                        specificationsContainer.append(row);
                    });

                    // Update engine and transmission table
                    var engineTransmissionContainer = $('#engineTransmissionContainer');
                    engineTransmissionContainer.empty(); // Clear existing content
                    $.each(data.engine, function (index, item) {
                        var row = '<div class="container-fluid">' +
